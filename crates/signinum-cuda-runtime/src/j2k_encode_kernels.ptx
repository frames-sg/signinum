    and.b32 %r14, %r3, 1;
    setp.eq.u32 %p3, %r14, 0;
    @%p3 bra VDWT_HEIGHT_EVEN;
    sub.u32 %r15, %r3, 1;
    bra VDWT_HEIGHT_READY;
