    add.u32 %r35, %r35, %r8;
    mul.lo.u32 %r36, %r34, %r1;
    add.u32 %r36, %r36, %r8;
    mul.lo.u32 %r37, %r32, %r1;
    add.u32 %r37, %r37, %r8;
    cvt.u64.u32 %rd20, %r35;
    cvt.u64.u32 %rd21, %r36;
    cvt.u64.u32 %rd22, %r37;
    mul.lo.u64 %rd20, %rd20, 4;
    mul.lo.u64 %rd21, %rd21, 4;
    mul.lo.u64 %rd22, %rd22, 4;
