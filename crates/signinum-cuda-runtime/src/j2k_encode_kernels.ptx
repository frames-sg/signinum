    add.f32 %f29, %f28, 0f3F000000;
    cvt.rmi.s32.f32 %s4, %f29;
    cvt.rn.f32.s32 %f30, %s4;
    mul.lo.u32 %r50, %r40, %r1;
    add.u32 %r50, %r50, %r8;
    cvt.u64.u32 %rd32, %r50;
