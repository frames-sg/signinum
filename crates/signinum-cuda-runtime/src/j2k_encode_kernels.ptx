    add.u32 %r45, %r43, 1;
    setp.lt.u32 %p9, %r45, %r3;
    @%p9 bra VDWT_BOTTOM_BOTTOM_IN_RANGE;
    mov.u32 %r45, %r15;
VDWT_BOTTOM_BOTTOM_IN_RANGE:
    mul.lo.u32 %r46, %r44, %r1;
