    cvt.u64.u32 %rd26, %r46;
    cvt.u64.u32 %rd27, %r47;
    cvt.u64.u32 %rd28, %r48;
    mul.lo.u64 %rd26, %rd26, 4;
    mul.lo.u64 %rd27, %rd27, 4;
    mul.lo.u64 %rd28, %rd28, 4;
